{
  "manifest_version": 3,
  "name": "PicZoomer - Image Zoom for Bluesky",
  "version": "1.0.0",
  "description": "Zoom and pan images in Bluesky's lightbox with the mouse wheel and drag.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PicZoomer - Image Zoom for Bluesky",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://bsky.app/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": []
}
